+//
+// BLESPlo.it patch to capture raw pairing response
+//
+/**
+ * Pairing command/response structure - public copy of private ble_sm_pair_cmd for callbacks
+ */
+struct ble_sm_pairing_params {
+    uint8_t io_cap;
+    uint8_t oob_data_flag;
+    uint8_t authreq;
+    uint8_t max_enc_key_size;
+    uint8_t init_key_dist;
+    uint8_t resp_key_dist;
+} __attribute__((packed));
+
+/**
+ * Callback to receive raw pairing response data
+ *
+ * @param conn_handle   Connection handle for the pairing
+ * @param rsp           Pointer to the pairing response command structure
+ * @param arg           Optional argument passed to callback
+ */
+typedef void (*ble_sm_pairing_rsp_fn)(uint16_t conn_handle,
+                                      const struct ble_sm_pairing_params *rsp,
+                                      void *arg);
+
+/**
+ * Set callback to receive pairing response packet
+ *
+ * @param cb        The callback function
+ * @param arg       Optional argument to pass to callback
+ */
+void ble_sm_set_pairing_rsp_cb(ble_sm_pairing_rsp_fn cb, void *arg);
+
+
+
 #ifdef __cplusplus
 }
 #endif
